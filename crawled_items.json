["## \uc138\ubbf8\ub098\uc77c\uc815 \uad6d\ud68c\uc758\uc6d0 \uc815\ucc45\uc138\ubbf8\ub098 \uc77c\uc815\uc785\ub2c8\ub2e4.", "- [\uc138\ubbf8\ub098 \uc601\uc0c1](https://ampos.nanet.go.kr/materialSemin", "- [\uc138\ubbf8\ub098\uc77c\uc815](https://ampos.nanet.go.kr/seminarList.do", "- [\uc138\ubbf8\ub098\uc815\ubcf4](https://ampos.nanet.go.kr/seminarList.do", "- [\uc815\ucc45\uc138\ubbf8\ub098](https://ampos.nanet.go.kr/materialSemina", "AI \uc2dc\ub300, \uace0\uacbd\ub825 \uc5ec\uc131\uacfc\ud559\uae30\uc220\uc778 \uacbd\ud5d8\uc758 \uad6d\uac00 \uc790\uc0b0\ud654\uc640 \ud65c\uc6a9 \uc804\ub7b5 \uc138\ubbf8\ub098 \ud45c\uc9c0 \uc774\ubbf8\uc9c0", "AI \uc778\ud504\ub77c \ud22c\uc790 \ucd09\uc9c4\uacfc \uc9c0\ub2a5 \uc218\ucd9c\uc744 \uc704\ud55c \uc804\ub7b5 \ud1a0\ub860\ud68c \uc138\ubbf8\ub098 \ud45c\uc9c0 \uc774\ubbf8\uc9c0", "K\uc804\ud1b5\ubb38\ud654 \uc138\uacc4\ud654\ub97c \uc704\ud55c \ubb38\ud654\uc720\uc0b0\ubc95 \uac1c\uc120\ubc29\uc548 \uc138\ubbf8\ub098 & \ud2b9\ubcc4\uc804\uc2dc\ud68c \uc138\ubbf8\ub098 \ud45c\uc9c0 \uc774\ubbf8\uc9c0", "[\uc18c\uac1c](https://www.energytransitionkorea.org/intro)-", "| \uc77c\uc2dc | \uc138\ubbf8\ub098 | \uc790\ub8cc |", "\uac80\uc0ac\uad8c\ub825 \uc624\ub0a8\uc6a9 \uc0ac\ub840\ub85c \ubcf8 \ud615\uc0ac\uc18c\uc1a1\ubc95 \uac1c\uc815 \ud1a0\ub860\ud68c \uc138\ubbf8\ub098 \ud45c\uc9c0 \uc774\ubbf8\uc9c0", "\uacc4\ud1b5\ud55c\uacc4\uac00\uaca9(SMP)", "\uacf5\uc801\uc785\uc591\uccb4\uacc4 \uac1c\ud3b8 1\ub144, \ub0a8\uaca8\uc9c4 \ubb38\uc81c\uc810\uacfc \uacfc\uc81c \uc138\ubbf8\ub098 \ud45c\uc9c0 \uc774\ubbf8\uc9c0", "\ub300\ud55c\ubbfc\uad6d \ubc18\ub3c4\uccb4 \uad6d\uac00\uc0b0\ub2e8\uc758 \ubbf8\ub798\uc804\ub7b5 \uc138\ubbf8\ub098 \ud45c\uc9c0 \uc774\ubbf8\uc9c0", "\uc138\ub300 \uac04 \uc815\uc758\uc640 \ud5cc\ubc95 \uac1c\uc815 \uc138\ubbf8\ub098 \ud45c\uc9c0 \uc774\ubbf8\uc9c0", "\uc2e4\uc2dc\uac04 \uc804\ub825\uc218\uae09\ud604\ud669 (\uc81c\uc8fc)", "\uc65c \uc5d0\ub108\uc9c0\uc804\ud658\uc778\uac00?", "\uc774 \ud45c\ub294 \uc138\ubbf8\ub098 \uc77c\uc815 \ub2ec\ub825\uc73c\ub85c \uc694\uc77c\uacfc \uc77c\uc790\ubcc4 \uc138\ubbf8\ub098\ub85c \uad6c\uc131\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4.", "\uc774 \ud45c\ub294 \uc138\ubbf8\ub098 \uc77c\uc815\uc73c\ub85c \uc77c\uc2dc, \uc138\ubbf8\ub098, \uc790\ub8cc\ub85c \uad6c\uc131\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4.", "\uc774\uc7ac\uba85 \uc815\ubd80\uac00 \ubc1c\ud45c\ud55c \ud638\ub0a8 \ubc18\ub3c4\uccb4\uc758 \ud5c8\uad6c\uc640 \uc2e4\uc0c1 \uc138\ubbf8\ub098 \ud45c\uc9c0 \uc774\ubbf8\uc9c0", "\uc7a5\uc560\uc778 \uac74\uac15\uc815\ucc45 \uac1c\uc120 \ub9b4\ub808\uc774 \uac04\ub2f4\ud68c \uc131\uacfc\uc640 \uacfc\uc81c \ud1a0\ub860\ud68c \uc138\ubbf8\ub098 \ud45c\uc9c0 \uc774\ubbf8\uc9c0", "\uc804\ub825\uac70\ub798\uc18c \uc801\uadf9\ud589\uc815 \ucd94\uc9c4\ubc29\uc548", "\uc804\ub825\ub370\uc774\ud130 \ud050\ub808\uc774\uc158 \uc11c\ube44\uc2a4", "\uc804\ub825\uc2dc\uc7a5\u00b7\uc804\ub825\uacc4\ud1b5 \uc6b4\uc601\uc815\ubcf4", "\uc804\ub825\uc2dc\uc7a5\uc6b4\uc601\uaddc\uce59 \ubc0f \uc138\ubd80\uaddc\uc815", "\uc804\ub825\uc2dc\uc7a5\uc6b4\uc601\uaddc\uce59 \uc544\uce74\uc774\ube0c", "\uc8fc\ud0dd\uacf5\uae09 \ud655\ub300\ub97c \uc704\ud55c \ubd80\ub3d9\uc0b0 PF \ud65c\uc131\ud654 \ubc29\uc548 \uc138\ubbf8\ub098 \ud45c\uc9c0 \uc774\ubbf8\uc9c0"]